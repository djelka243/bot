      "parameters": {
        "jsCode": "const d = $('IPN - Extraire Données1').first().json;\n\nlet rawNumber = String(d.chatId).replace(/[^0-9]/g, '');\nconst to = '+' + rawNumber;\nconst text = `✅ *Paiement confirmé !*\\n\\nVotre commande ${d.order_ref} est validée via *${d.payment_channel}*.\\nMerci pour votre achat ! Notre équipe prépare votre colis 🎁`;\n\nreturn [{\n  json: {\n    messaging_product: 'whatsapp',\n    to: to,\n    type: 'text',\n    text: { body: text, preview_url: false }\n  }\n}];"
      },
