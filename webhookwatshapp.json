      "parameters": {
        "jsCode": "const d = $('IPN - Extraire Données1').first().json;\n\nif (!d.chatId || !d.order_ref || !d.payment_status) {\n  throw new Error(`Données manquantes: chatId=${d.chatId}, order_ref=${d.order_ref}, status=${d.payment_status}`);\n}\n\nlet rawNumber = String(d.chatId).replace(/[^0-9]/g, '');\nconst to = '+' + rawNumber;\nconst text = `⚠️ *Problème de paiement*\\n\\nUne erreur est survenue pour la commande ${d.order_ref}.\\nStatut reçu : ${d.payment_status}\\n\\nContactez notre support si le problème persiste.`;\n\nreturn [{\n  json: {\n    messaging_product: 'whatsapp',\n    to: to,\n    type: 'text',\n    text: { body: text, preview_url: false }\n  }\n}];"
      },
