    {
      "parameters": {
        "jsCode": "const PAGE_SIZE = 10;\nconst nav     = $('Router Navigation').first().json;\nconst catId   = nav.navCatId;\nconst offset  = parseInt(nav.navOffset, 10);\nconst rows    = $input.all().map(i => i.json);\nconst total   = rows.length > 0 ? Number(rows[0]._total ?? rows.length) : 0;\nconst H       = '\\u200B'; // séparateur invisible\n\nif (rows.length === 0) {\n  return [{ json: {\n    chatId: nav.chatId,\n    sendType: 'text',\n    text: '😕 Aucun produit dans cette catégorie.',\n    keyboard: [[{ text: '🏠 Accueil' }]]\n  }}];\n}\n\nconst keyboard = rows.map(r => [{ text: r.name + H + r.id }]);\n\nconst navRow = [];\nif (offset > 0)                  navRow.push({ text: '⬅️ Page préc.' + H + catId + H + (offset - PAGE_SIZE) });\nif (offset + PAGE_SIZE < total)  navRow.push({ text: 'Page suiv. ➡️' + H + catId + H + (offset + PAGE_SIZE) });\nif (navRow.length) keyboard.push(navRow);\nkeyboard.push([{ text: '🏠 Accueil' }]);\n\nconst page = Math.floor(offset / PAGE_SIZE) + 1;\nconst totalPages = Math.ceil(total / PAGE_SIZE);\n\nreturn [{ json: {\n  chatId:   nav.chatId,\n  sendType: 'text',\n  text: `🛍️ Produits — page ${page}/${totalPages}\\nChoisissez un produit :`,\n  keyboard\n}}];"
      },
      "id": "91400f6f-6179-4348-ba80-b02f58fc9bee",
      "name": "Handle Pagination",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2288,
        2560
      ]
    },
    {
      "parameters": {
        "jsCode": "const BASE_URL = 'https://mhbeauty.shop/storage/';\nconst nav    = $('Router Navigation').first().json;\nconst rows   = $input.all().map(i => i.json);\nconst p      = rows[0];\nconst H      = '\\u200B';\n\nif (!p || !p.name) {\n  return [{ json: {\n    chatId:   nav.chatId,\n    sendType: 'text',\n    text:     '😕 Produit introuvable.',\n    keyboard: [[{ text: '🏠 Accueil' }]]\n  }}];\n}\n\nconst rawUrl   = (p.photo_url ?? '').trim();\nconst photoUrl = rawUrl ? (rawUrl.startsWith('http') ? rawUrl : BASE_URL + rawUrl.replace(/^\\//, '')) : '';\nconst caption  = `🌟 ${p.name}\\n\\n📝 ${p.description ?? ''}\\n💵 Prix : ${p.price} $\\n📐 Taille : ${p.taille ?? 'N/A'}\\n\\nVeuillez indiquer la quantité souhaitée. 😊`;\n\nconst keyboard = [\n  [{ text: '🛒 Commander : ' + p.name + H + p.id + H + p.price }],\n  [{ text: '⬅️ Retour catégorie' + H + p.categorie_id + H + '0' }, { text: '🏠 Accueil' }]\n];\n\nreturn [{ json: {\n  chatId:   nav.chatId,\n  sendType: photoUrl ? 'photo' : 'text',\n  text:     caption,\n  photoUrl,\n  keyboard\n}}];"
      },
