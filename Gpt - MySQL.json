    {
      "parameters": {
        "jsCode": "const BASE_URL = 'https://mhbeauty.shop/storage/';\nconst output  = $input.first().json.output ?? '';\nconst chatId  = $('Normaliser Telegram').first().json.chatId;\nconst H       = '\\u200B';\n\n// ── show_categories ──\nif (output.includes('\"action\":\"show_categories\"')) {\n  return [{ json: { chatId, routeTo: 'cat', navCatId: '', navOffset: '0', navProdId: '' } }];\n}\n\n// ── display_product (recherche texte) ──\nconst displayMatch = output.match(/\\{\\s*\"action\"\\s*:\\s*\"display_product\"[\\s\\S]*?\\}/);\nif (displayMatch) {\n  try {\n    const p      = JSON.parse(displayMatch[0]);\n    let rawUrl   = (p.photo_url ?? '').trim();\n    const photoUrl = rawUrl ? (rawUrl.startsWith('http') ? rawUrl : BASE_URL + rawUrl.replace(/^\\//, '')) : '';\n    const cleanText = output.replace(displayMatch[0], '').trim();\n    const caption   = `🌟 ${p.name}\\n\\n📝 ${p.description}\\n💵 Prix : ${p.price}\\n📐 Taille : ${p.taille}\\n\\n${cleanText || 'Veuillez indiquer la quantité souhaitée. 😊'}`;\n    const keyboard  = [\n      [{ text: '🛒 Commander : ' + p.name + H + p.prod_id + H + p.price }],\n      [{ text: '⬅️ Retour catégorie' + H + p.cat_id + H + '0' }, { text: '🏠 Accueil' }]\n    ];\n    return [{ json: {\n      chatId,\n      sendType: photoUrl ? 'photo' : 'text',\n      text:     caption,\n      photoUrl,\n      keyboard\n    }}];\n  } catch(e) {}\n}\n\n// ── Texte simple (commande, questions, etc.) ──\nconst clean = output.replace(/\\{[\\s\\S]*?\\}/g, '').trim();\nreturn [{ json: {\n  chatId,\n  sendType: 'text',\n  text:     clean || '...',\n  keyboard: [[{ text: '🏠 Accueil' }]]\n}}];"
      },
