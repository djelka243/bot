    {
      "parameters": {
        "jsCode": "const msg       = $input.first().json.userMessage ?? '';\nconst chatId    = $input.first().json.chatId;\nconst sessionId = $input.first().json.sessionId;\nconst orderRef  = $input.first().json.orderRef;\nconst userName  = $input.first().json.userName;\n\nlet routeTo   = 'agent';\nlet navCatId  = '';\nlet navOffset = 0;\nlet navProdId = '';\n\n// Détection des boutons avec ID caché (séparateur \\u200B)\nconst hidden = '\\u200B';\n\nif (msg.startsWith('📂 ') && msg.includes(hidden)) {\n  // Catégorie\n  const id = msg.split(hidden).pop();\n  if (id) { routeTo = 'page'; navCatId = id; navOffset = 0; }\n} else if (msg.startsWith('⬅️ ') && msg.includes(hidden)) {\n  // Retour catégorie ou Page préc.\n  const parts = msg.split(hidden);\n  if (parts.length >= 3) {\n    navCatId = parts[1];\n    navOffset = parseInt(parts[2], 10) || 0;\n    routeTo = 'page';\n  }\n} else if (msg.startsWith('Page suiv.') && msg.includes(hidden)) {\n  const parts = msg.split(hidden);\n  if (parts.length >= 3) {\n    navCatId = parts[1];\n    navOffset = parseInt(parts[2], 10) || 0;\n    routeTo = 'page';\n  }\n} else if (msg.includes(hidden) && !msg.startsWith('📂') && !msg.startsWith('⬅️') && !msg.startsWith('Page suiv.') && !msg.startsWith('🛒')) {\n  // Produit (NomProduit​ID)\n  const id = msg.split(hidden).pop();\n  if (id) { routeTo = 'prod'; navProdId = id; }\n} else if (msg.startsWith('🏠 Accueil')) {\n  routeTo = 'cat';\n} else if (msg.startsWith('🛒 Commander : ')) {\n  // Le bouton Commander est envoyé à l'agent (pour collecte)\n  routeTo = 'agent';\n} else if (msg === '__CAT__') {\n  routeTo = 'cat';\n} else if (msg.startsWith('__PAGE__')) {\n  const parts = msg.replace('__PAGE__', '').split('__');\n  navCatId  = parts[0] ?? '';\n  navOffset = parseInt(parts[1] ?? '0', 10);\n  routeTo   = 'page';\n} else if (msg.startsWith('__PROD__')) {\n  navProdId = msg.replace('__PROD__', '').trim();\n  routeTo   = 'prod';\n} else if (msg.startsWith('__NAV_STATE__') || msg.startsWith('__PROD_STATE__') || msg.startsWith('__FIND_CAT__')) {\n  routeTo = 'ignore';\n}\n\nreturn [{ json: { chatId, userMessage: msg, userName, sessionId, orderRef, routeTo, navCatId, navOffset: navOffset.toString(), navProdId } }];"
      },
